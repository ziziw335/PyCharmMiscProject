# ========== 必填（启动前必须填写）==========
BOT_TOKEN=

# secrets_demo.py 示例用（可选，真实值只写在 .env）
# DATABASE_PASSWORD=
# API_TOKEN=

# 数据库二选一：
# A) 本机 SQLite（默认，零配置）
# DATABASE_URL=sqlite:///data/bot.db
# PGSSLMODE=
# B) 云 PostgreSQL（Neon 免费）— 复制连接串后运行 setup_cloud_postgres.py
# DATABASE_URL=postgresql://用户:密码@ep-xxx.neon.tech/neondb?sslmode=require
# PGSSLMODE=require

DATABASE_URL=sqlite:///data/bot.db
PGSSLMODE=

BOT_OWNER_ID=
SUPER_ADMIN_ID=
WEB_TOKEN=
# 群账单只读链接签名密钥（不填则沿用 WEB_TOKEN；建议单独设一长串随机值）
# GROUP_VIEW_SECRET=
# GROUP_VIEW_TOKEN_DAYS=7
TELEGRAM_SECRET_TOKEN=

# ========== 服务端口 ==========
PORT=10000
WEB_PORT=8081
BOT_BASE_URL=http://127.0.0.1:10000
WEB_BASE_URL=http://127.0.0.1:8081
# 群成员能打开的公网地址（ngrok 或服务器 https，填后重启 Bot）
# PUBLIC_WEB_BASE_URL=https://xxxx.ngrok-free.app

# ========== 可选 ==========
PGSSLMODE=require
# TRONGRID_API_KEY=
# 租赁收款地址（必须是你自己的钱包，勿用他人地址）
PAYMENT_ADDRESS=
PAYMENT_SUPPORT=
# AUTO_PAY_INTERVAL=15
# WELCOME_ENABLED=1

# Have I Been Pwned（泄露自查）https://haveibeenpwned.com/API/Key
HIBP_API_KEY=
HIBP_USER_AGENT=PyCharmMiscProject-TelegramBot/1.0
HIBP_COOLDOWN_SECONDS=8
HIBP_PAGE_SIZE=10

# 银行卡 BIN 查询（仅发卡行/卡类型；一般不能返回姓名手机）
# BANK_CARD_API_URL=https://your-api.example.com/bank?cardNo={card}
# BANK_CARD_API_KEY=

# 银行卡四要素核验（合规：验证姓名+身份证+卡号+手机是否一致）
# 易源 https://www.showapi.com 搜索「银行卡四要素」购买后复制 APPCODE
# BANK_VERIFY_APPCODE=你的APPCODE
# BANK_VERIFY_API_URL=https://ali-bankcard4.showapi.com/bank4
